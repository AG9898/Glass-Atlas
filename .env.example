# Database — Neon PostgreSQL (serverless HTTP)
# Create a project at neon.tech, enable pgvector: CREATE EXTENSION IF NOT EXISTS vector;
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Auth.js — GitHub OAuth (create app at github.com/settings/developers)
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Required on Vercel — prevents silent OAuth callback failures
AUTH_TRUST_HOST=true

# LLM — OpenRouter (openrouter.ai)
OPENROUTER_API_KEY=

# Public — accessible in client components via $env/static/public
PUBLIC_SITE_URL=http://localhost:5173
