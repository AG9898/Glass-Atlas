# Database — Neon PostgreSQL (serverless HTTP driver)
# Create a project at neon.tech, enable pgvector: CREATE EXTENSION IF NOT EXISTS vector;
# All Glass Atlas tables live in the glass_atlas schema (not public).
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Auth.js
# Generate AUTH_SECRET with: openssl rand -hex 32
# AUTH_GITHUB_ID / AUTH_GITHUB_SECRET: same GitHub OAuth app as Techy
#   (Techy calls them GITHUB_CLIENT_ID / GITHUB_CLIENT_SECRET — same values, different names)
# Callback URL for local dev:  http://localhost:5173/auth/callback/github
# Callback URL for production: https://your-domain.com/auth/callback/github
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# Local-only auth bypass for localhost testing (development only)
# AUTH_BYPASS=TRUE
# AUTH_TRUST_HOST must NOT be set — Railway does not require it.

# OpenRouter — same account as Techy but use a separate API key for this project
OPENROUTER_API_KEY=

# Public — browser-visible, used for OG tags and sitemap
PUBLIC_SITE_URL=http://localhost:5173

# Railway Storage Bucket — required only when first-party media uploads are enabled (tasks 19-21)
BUCKET=
ENDPOINT=https://storage.railway.app
REGION=auto
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=

# Optional overrides — only set to change defaults
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=google/gemini-2.0-flash-001
# OPENROUTER_REVIEW_MODEL=openrouter/free
# EMBEDDING_MODEL=text-embedding-3-small
# CHAT_RATE_LIMIT=10
